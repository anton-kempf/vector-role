FROM {{ item.image }}

ENV container docker

RUN if command -v apt-get >/dev/null 2>&1; then \
      apt-get update && \
      DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        systemd systemd-sysv python3 sudo ca-certificates curl && \
      apt-get clean && rm -rf /var/lib/apt/lists/*; \
    elif command -v dnf >/dev/null 2>&1; then \
      dnf -y install systemd python3 sudo ca-certificates curl && \
      dnf clean all; \
    elif command -v yum >/dev/null 2>&1; then \
      yum -y install systemd python3 sudo ca-certificates curl && \
      yum clean all; \
    fi

RUN mkdir -p /tmp /var/tmp && chmod 1777 /tmp /var/tmp

VOLUME ["/sys/fs/cgroup"]

CMD ["/sbin/init"]
